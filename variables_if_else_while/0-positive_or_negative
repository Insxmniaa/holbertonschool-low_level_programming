#include <stdlib.h>
#include <time.h>
#include <stdio.h>

/**
 * main = Entry point
 *
 * Return: Always 0 (Success)
 */

int main(void)
{
	int n;

	srand(time(0));
	n = rand() - RAND_MAX / 2;

	if(n > 0) {
		printf("d% is positive");
	}
	if else(n = 0) {
		printf("%d is 0");
	}

	else(n < 0) {
		printf("%d is negative");
	}
	
	return (0);
}
